  },
  "bugs": {
    "url": "https://github.com/fabiorenner-hub/hmip-hcu-webweather/issues"
  },
  "keywords": [
    "homematic",
    "hmip",
    "hcu",
    "weather",
    "open-meteo",
    "smart-home",
    "climate-sensor"
  ],
  "main": "plugin.js",
  "scripts": {
